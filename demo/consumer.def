Bootstrap: docker
From: nvcr.io/nvidia/pytorch:24.12-py3

%labels
    Author cwang31
    Description PeakNet streaming pipeline consumer (GPU inference + CXI writer)

%post
    # --break-system-packages needed: NVIDIA container marks Python as externally managed (PEP 668)

    # Install peaknet-pipeline-ray first — needs workaround for flat-layout issue
    # (repo has 'archive/' dir that confuses setuptools auto-discovery)
    cd /tmp
    git clone --depth 1 https://github.com/carbonscott/peaknet-pipeline-ray
    cd peaknet-pipeline-ray
    # Tell setuptools which package to include (avoids 'archive' dir conflict)
    printf '\n[tool.setuptools.packages.find]\ninclude = ["peaknet_pipeline_ray*"]\n' >> pyproject.toml
    pip install --break-system-packages .
    cd /
    rm -rf /tmp/peaknet-pipeline-ray

    # Install remaining packages
    # hydra-core + omegaconf: undeclared deps of peaknet-pipeline-ray
    # transformers + timm: undeclared deps of peaknet (convnextv2 backbone)
    pip install --break-system-packages \
        "git+https://github.com/carbonscott/peaknet" \
        "git+https://github.com/carbonscott/cxi-pipeline-ray" \
        "ray[default]>=2.0.0" \
        "hydra-core>=1.3.0" \
        "omegaconf>=2.3.0" \
        "transformers==4.46.3" \
        "timm>=0.9.0"

%environment
    # Ensure CUDA libraries are visible
    export LD_LIBRARY_PATH=/usr/local/cuda/lib64:$LD_LIBRARY_PATH

%runscript
    exec "$@"
